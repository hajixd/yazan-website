DATABENTO_API_KEY=
# mbp-1 is the fastest accurate default for this app when your Databento plan allows it.
# Use trades to stream only exact last-sale ticks, or bbo-1s for a lighter 1-second display quote.
DATABENTO_PRICE_SCHEMA=mbp-1
# Set true only when the Databento key is entitled for mbp-10 depth.
DATABENTO_ENABLE_DEPTH=false
PYTHON_EXECUTABLE=python

# Firebase Admin for server-side market candle storage
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_PREFIX=yazan-website
FIREBASE_MARKET_DATA_COLLECTION=yazanMarketAssets

# Telegram alert group
NEXT_PUBLIC_TELEGRAM_GROUP_URL=https://t.me/RomanCapital
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
