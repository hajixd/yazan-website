rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /yazanMarketAssets/{assetId} {
      allow read, write: if false;

      match /timeframes/{timeframeId} {
        allow read, write: if false;

        match /candles/{candleId} {
          allow read, write: if false;
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
